---
/**
 * FEAT-007: Sección "Ajedrecistas famosos"
 * - AC-1: id="ajedrecistas"
 * - AC-2: 9 ajedrecistas en orden cronológico
 * - AC-5/6/7: Grid responsive 1→2→3 columnas
 * - AC-8: Stagger de entrada con Intersection Observer
 */
import PlayerCard from '../ui/PlayerCard.astro';
import { players } from '../../data/players';
---

<section id="ajedrecistas" class="section-players">
  <div class="container">

    <!-- Encabezado -->
    <div class="section-players__header reveal">
      <p class="section-label">Grandes maestros</p>
      <h2 class="section-players__title">Ajedrecistas famosos</h2>
      <div class="section-divider"></div>
      <p class="section-players__lead">
        Genios que elevaron el ajedrez a la categoría de arte.
        Sus partidas, estilos y personalidades siguen inspirando a millones de jugadores en todo el mundo.
      </p>
    </div>

    <!-- Grid de tarjetas (AC-5, AC-6, AC-7, AC-8) -->
    <div class="players-grid">
      {players.map((player, i) => (
        <PlayerCard
          player={player}
          delay={((i % 3) + 1) * 100}
        />
      ))}
    </div>

  </div>
</section>

<style>
  .section-players {
    padding-block: var(--space-24);
    background: var(--color-bg);
  }

  /* ─── Encabezado ─────────────────────────────────────────────────────────── */
  .section-players__header {
    text-align: center;
    margin-bottom: var(--space-16);
  }

  .section-label {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-brown-main);
    margin-bottom: var(--space-3);
  }

  .section-players__title {
    font-size: clamp(var(--text-3xl), 5vw, var(--text-5xl));
    color: var(--color-text);
    margin-bottom: var(--space-4);
  }

  .section-divider {
    width: 48px;
    height: 3px;
    background: var(--color-brown-main);
    margin-block: var(--space-4);
    border-radius: var(--radius-full);
    margin-inline: auto;
  }

  .section-players__lead {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    max-width: 60ch;
    margin-inline: auto;
    line-height: 1.7;
  }

  /* ─── Grid responsive (AC-5, AC-6, AC-7) ────────────────────────────────── */
  .players-grid {
    display: grid;
    /* AC-5: móvil → 1 columna */
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  /* AC-5: móvil compacto → 2 columnas en pantallas >= 480px */
  @media (min-width: 480px) {
    .players-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* AC-6: tablet → 2-3 columnas */
  @media (min-width: 769px) {
    .players-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* AC-7: desktop → 3 columnas (mantenemos 3 para que 9 quede en 3 filas perfectas) */
  @media (min-width: 1200px) {
    .players-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-8);
    }
  }
</style>

<script>
  // AC-8: Intersection Observer para stagger de entrada
  const cards = document.querySelectorAll('#ajedrecistas .reveal');
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.08 }
  );
  cards.forEach(card => observer.observe(card));
</script>
