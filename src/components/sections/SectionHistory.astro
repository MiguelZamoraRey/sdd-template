---
/**
 * FEAT-006: Sección "Mucha historia" — timeline cronológico
 * - AC-1: id="historia"
 * - AC-2: 8 hitos históricos relevantes
 * - AC-3: Timeline con fecha/época y descripción
 * - AC-4: Layout vertical en móvil
 * - AC-5: Alternado izq/der en desktop (zigzag)
 * - AC-6: Animación escalonada con Intersection Observer
 * - AC-7: <h2> sección, <h3> hitos, <time> con datetime
 */

interface TimelineItem {
  era: string;
  datetime: string;
  title: string;
  description: string;
  icon: string;
}

const timeline: TimelineItem[] = [
  {
    era: 'Siglo VI d.C.',
    datetime: '0550',
    title: 'Los orígenes: el Chaturanga',
    description:
      'En los valles del subcontinente indio nace el Chaturanga, un juego de estrategia que simulaba la batalla entre cuatro divisiones del ejército: infantería, caballería, elefantes y carros de guerra. Cada pieza ya poseía un movimiento diferente y el objetivo era dominar al rey enemigo.',
    icon: '♟',
  },
  {
    era: 'Siglo VII',
    datetime: '0600',
    title: 'El Shatranj persa',
    description:
      'Los persas adoptan el juego y lo rebautizan como Shatranj. Introducen exclamaciones como "Shāh!" (¡rey!) y "Shāh māt!" (¡el rey ha muerto!), de donde deriva el término "jaque mate". El ajedrez se convierte en símbolo de inteligencia y nobleza en la corte sasánida.',
    icon: '🏛',
  },
  {
    era: 'Siglos IX–X',
    datetime: '0850',
    title: 'La expansión árabe',
    description:
      'Con la expansión del Islam, el Shatranj se difunde por todo el mundo árabe y llega a la Península Ibérica y al norte de África. Maestros como al-Adli y as-Suli desarrollan los primeros estudios teóricos y problemas de ajedrez, sentando las bases del análisis moderno.',
    icon: '🌙',
  },
  {
    era: 'Siglo XV',
    datetime: '1475',
    title: 'Europa lo transforma',
    description:
      'En la España de los Reyes Católicos surge el ajedrez moderno. La reina (antes el visir, pieza débil) adquiere su poder actual, moviéndose cualquier número de casillas. El alfil también gana alcance. Nacen el enroque y la captura al paso, completando el juego tal como lo conocemos hoy.',
    icon: '♛',
  },
  {
    era: '1886',
    datetime: '1886',
    title: 'El primer campeón mundial',
    description:
      'Wilhelm Steinitz derrota a Johannes Zukertort en el primer match oficial por el campeonato del mundo. Steinitz no solo gana el título; también funda la escuela posicional, demostrando que el ajedrez es una ciencia regida por principios lógicos y no únicamente por el talento intuitivo.',
    icon: '🏆',
  },
  {
    era: '1972',
    datetime: '1972',
    title: 'Fischer vs Spassky: la batalla de la Guerra Fría',
    description:
      'En Reikiavik, Bobby Fischer arrebata el título mundial al soviético Boris Spassky en el enfrentamiento más mediático de la historia del ajedrez. La partida trasciende el tablero: es una metáfora de la rivalidad entre Estados Unidos y la URSS, y Fischer se convierte en una figura de dimensión mítica.',
    icon: '♔',
  },
  {
    era: '1997',
    datetime: '1997',
    title: 'Deep Blue vence a Kasparov',
    description:
      'El superordenador Deep Blue de IBM derrota al campeón mundial Garry Kasparov en una serie de seis partidas, marcando un hito histórico en la inteligencia artificial. Por primera vez, una máquina supera al mejor ajedrecista del mundo, abriendo debates filosóficos sobre la mente humana y la creatividad.',
    icon: '🤖',
  },
  {
    era: 'Años 2020',
    datetime: '2020',
    title: 'La era online y el renacimiento global',
    description:
      'El confinamiento de 2020 dispara el número de jugadores en plataformas como Chess.com y Lichess hasta los cientos de millones. La serie "El Gambito de Dama" convierte el ajedrez en fenómeno pop mundial. Magnus Carlsen domina el juego clásico, blitz y rápido, y la inteligencia artificial redefine la preparación de los grandes maestros.',
    icon: '🌐',
  },
];
---

<section id="historia" class="section-history">
  <div class="container">

    <!-- Encabezado -->
    <div class="section-history__header reveal">
      <p class="section-label">Un viaje en el tiempo</p>
      <h2 class="section-history__title">Mucha historia</h2>
      <div class="section-divider section-divider--center section-divider--light"></div>
      <p class="section-history__lead">
        Más de 1500 años de estrategia, conquistas y genialidad.
        Del subcontinente indio a los servidores de la inteligencia artificial.
      </p>
    </div>

    <!-- Timeline (AC-3, AC-4, AC-5) -->
    <div class="timeline" role="list">
      {timeline.map((item, i) => (
        <article
          class={`timeline__item reveal reveal-delay-${(i % 3) + 1}`}
          role="listitem"
          data-index={i}
        >
          <!-- Punto central de la línea -->
          <div class="timeline__dot" aria-hidden="true">
            <span class="timeline__dot-inner">{item.icon}</span>
          </div>

          <!-- Contenido del hito -->
          <div class="timeline__content">
            <time class="timeline__era" datetime={item.datetime}>{item.era}</time>
            <h3 class="timeline__title">{item.title}</h3>
            <p class="timeline__desc">{item.description}</p>
          </div>
        </article>
      ))}
    </div>

  </div>
</section>

<style>
  .section-history {
    padding-block: var(--space-24);
    background: var(--color-bg-dark);
    color: var(--color-white);
  }

  /* ─── Encabezado ─────────────────────────────────────────────────────────── */
  .section-history__header {
    text-align: center;
    margin-bottom: var(--space-16);
  }

  .section-label {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-brown-light);
    margin-bottom: var(--space-3);
  }

  .section-history__title {
    font-size: clamp(var(--text-3xl), 5vw, var(--text-5xl));
    color: var(--color-white);
    margin-bottom: var(--space-4);
  }

  .section-divider--light {
    background: var(--color-brown-light);
  }

  .section-divider--center {
    margin-inline: auto;
  }

  .section-history__lead {
    font-size: var(--text-lg);
    color: rgba(255, 255, 255, 0.6);
    max-width: 55ch;
    margin-inline: auto;
    line-height: 1.7;
  }

  /* ─── Timeline (AC-4: vertical móvil) ───────────────────────────────────── */
  .timeline {
    position: relative;
    max-width: 900px;
    margin-inline: auto;
  }

  /* Línea vertical central */
  .timeline::before {
    content: '';
    position: absolute;
    left: 20px;
    top: 0;
    bottom: 0;
    width: 2px;
    background: linear-gradient(
      to bottom,
      transparent,
      var(--color-brown-main) 8%,
      var(--color-green-main) 92%,
      transparent
    );
  }

  .timeline__item {
    position: relative;
    padding-left: 60px;
    padding-bottom: var(--space-12);
  }

  .timeline__item:last-child {
    padding-bottom: 0;
  }

  /* ─── Punto / dot ────────────────────────────────────────────────────────── */
  .timeline__dot {
    position: absolute;
    left: 0;
    top: 0;
    width: 40px;
    height: 40px;
    background: var(--color-bg-dark);
    border: 2px solid var(--color-brown-main);
    border-radius: var(--radius-full);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: border-color var(--duration-normal) var(--ease-smooth),
                box-shadow var(--duration-normal) var(--ease-smooth);
  }

  .timeline__item:hover .timeline__dot {
    border-color: var(--color-brown-light);
    box-shadow: 0 0 16px rgba(196, 149, 106, 0.4);
  }

  .timeline__dot-inner {
    font-size: var(--text-base);
    line-height: 1;
  }

  /* ─── Contenido ──────────────────────────────────────────────────────────── */
  .timeline__content {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--color-border-dark);
    border-radius: var(--radius-lg);
    padding: var(--space-6) var(--space-8);
    transition: background var(--duration-normal) var(--ease-smooth),
                border-color var(--duration-normal) var(--ease-smooth);
  }

  .timeline__item:hover .timeline__content {
    background: rgba(255, 255, 255, 0.07);
    border-color: rgba(196, 149, 106, 0.2);
  }

  .timeline__era {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-brown-light);
    margin-bottom: var(--space-2);
  }

  .timeline__title {
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--color-white);
    margin-bottom: var(--space-3);
    line-height: 1.3;
  }

  .timeline__desc {
    font-size: var(--text-base);
    color: rgba(255, 255, 255, 0.65);
    line-height: 1.75;
    max-width: none;
  }

  /* ─── AC-5: Zigzag en desktop ────────────────────────────────────────────── */
  @media (min-width: 1024px) {
    .timeline::before {
      left: 50%;
      transform: translateX(-50%);
    }

    .timeline__item {
      display: grid;
      grid-template-columns: 1fr 40px 1fr;
      align-items: start;
      gap: var(--space-6);
      padding-left: 0;
      padding-bottom: var(--space-16);
    }

    /* Ítems pares → contenido a la izquierda */
    .timeline__item:nth-child(odd) .timeline__content {
      grid-column: 1;
      text-align: right;
    }

    .timeline__item:nth-child(odd) .timeline__dot {
      grid-column: 2;
      position: static;
      margin-inline: auto;
    }

    .timeline__item:nth-child(odd)::after {
      content: '';
      grid-column: 3;
    }

    /* Ítems impares → contenido a la derecha */
    .timeline__item:nth-child(even) .timeline__content {
      grid-column: 3;
    }

    .timeline__item:nth-child(even) .timeline__dot {
      grid-column: 2;
      position: static;
      margin-inline: auto;
    }

    .timeline__item:nth-child(even)::before {
      content: '';
      grid-column: 1;
    }

    /* Alinear el dot verticalmente con el top del contenido */
    .timeline__dot {
      margin-top: var(--space-4);
    }
  }
</style>

<script>
  // AC-6: Intersection Observer para animaciones escalonadas
  const reveals = document.querySelectorAll('#historia .reveal');
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1 }
  );
  reveals.forEach(el => observer.observe(el));
</script>
