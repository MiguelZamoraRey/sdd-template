---
/**
 * FEAT-005: Sección "Un juego sencillo"
 * - AC-1: id="el-juego"
 * - AC-2: Tablero, 6 piezas con movimientos, reglas básicas
 * - AC-3: SVG de cada pieza + nombre + descripción
 * - AC-4/5: Grid responsive 2 cols (móvil) → 3 cols (desktop)
 * - AC-6: Animación entrada con Intersection Observer (clase .reveal)
 * - AC-7: <h2> para sección, <h3> para subsecciones
 * - CE-1: Fallback texto si SVG no carga
 */

import kingUrl   from '../../assets/icons/pieces/king.svg?url';
import queenUrl  from '../../assets/icons/pieces/queen.svg?url';
import rookUrl   from '../../assets/icons/pieces/rook.svg?url';
import bishopUrl from '../../assets/icons/pieces/bishop.svg?url';
import knightUrl from '../../assets/icons/pieces/knight.svg?url';
import pawnUrl   from '../../assets/icons/pieces/pawn.svg?url';

const pieces = [
  {
    name: 'Rey',
    slug: 'king',
    icon: kingUrl,
    movement: 'Se mueve una casilla en cualquier dirección. Es la pieza más importante: su captura decide la partida.',
    value: '∞',
  },
  {
    name: 'Reina',
    slug: 'queen',
    icon: queenUrl,
    movement: 'La pieza más poderosa. Se mueve cualquier número de casillas en línea recta o diagonal.',
    value: '9',
  },
  {
    name: 'Torre',
    slug: 'rook',
    icon: rookUrl,
    movement: 'Se mueve cualquier número de casillas en horizontal o vertical. Participa en el enroque.',
    value: '5',
  },
  {
    name: 'Alfil',
    slug: 'bishop',
    icon: bishopUrl,
    movement: 'Se mueve cualquier número de casillas en diagonal. Siempre permanece en el mismo color.',
    value: '3',
  },
  {
    name: 'Caballo',
    slug: 'knight',
    icon: knightUrl,
    movement: 'Se mueve en "L": dos casillas en una dirección y una perpendicular. Es la única pieza que salta sobre otras.',
    value: '3',
  },
  {
    name: 'Peón',
    slug: 'pawn',
    icon: pawnUrl,
    movement: 'Avanza una casilla (o dos desde su posición inicial) y captura en diagonal. Puede coronar al llegar al final.',
    value: '1',
  },
];

const rules = [
  {
    icon: '♔',
    title: 'Objetivo del juego',
    desc: 'El objetivo es dar jaque mate al rey del oponente: ponerlo bajo ataque sin posibilidad de escape.',
  },
  {
    icon: '⚔',
    title: 'Jaque y jaque mate',
    desc: 'Un rey está en jaque cuando una pieza contraria lo ataca. Si no puede escapar del jaque, es jaque mate y la partida termina.',
  },
  {
    icon: '🏰',
    title: 'Enroque',
    desc: 'Movimiento especial donde el rey se desplaza dos casillas hacia la torre y ésta salta al otro lado del rey.',
  },
  {
    icon: '⚡',
    title: 'Captura al paso',
    desc: 'Si un peón avanza dos casillas desde su posición inicial y pasa junto a un peón enemigo, éste puede capturarlo "al paso".',
  },
  {
    icon: '👑',
    title: 'Coronación',
    desc: 'Cuando un peón llega al extremo del tablero, puede coronarse y convertirse en cualquier pieza (normalmente reina).',
  },
  {
    icon: '🤝',
    title: 'Tablas',
    desc: 'La partida acaba en empate por ahogado, repetición de posición, material insuficiente o acuerdo mutuo.',
  },
];
---

<section id="el-juego" class="section-rules">
  <div class="container">

    <!-- Encabezado -->
    <div class="section-rules__header reveal">
      <p class="section-label">Aprende a jugar</p>
      <h2 class="section-rules__title">Un juego sencillo</h2>
      <div class="section-divider"></div>
      <p class="section-rules__lead">
        Sesenta y cuatro casillas, treinta y dos piezas y un objetivo: poner al rey en jaque mate.
        La sencillez de las reglas esconde una profundidad infinita.
      </p>
    </div>

    <!-- Subsección 1: El tablero -->
    <div class="section-rules__board-info reveal">
      <div class="board-visual" aria-hidden="true">
        <div class="board-grid">
          {Array.from({ length: 64 }).map((_, i) => {
            const row = Math.floor(i / 8);
            const col = i % 8;
            const isLight = (row + col) % 2 === 0;
            return <div class={`board-cell ${isLight ? 'board-cell--light' : 'board-cell--dark'}`}></div>;
          })}
        </div>
        <p class="board-label">8 × 8 = 64 escaques</p>
      </div>
      <div class="board-text">
        <h3>El tablero</h3>
        <p>
          El tablero de ajedrez es una cuadrícula de <strong>8 × 8 casillas</strong>,
          alternando colores claros y oscuros, con un total de 64 escaques.
          Se orienta con una casilla <em>clara</em> en la esquina inferior derecha de cada jugador.
        </p>
        <p>
          Las columnas se denominan <strong>columnas a–h</strong> y las filas
          <strong>filas 1–8</strong>, formando un sistema de coordenadas único
          para cada casilla (e.g. e4, d5).
        </p>
      </div>
    </div>

    <!-- Subsección 2: Las piezas (AC-3, AC-4, AC-5) -->
    <div class="section-rules__pieces-header reveal">
      <h3>Las piezas</h3>
      <p>Cada jugador comienza con 16 piezas: 1 rey, 1 reina, 2 torres, 2 alfiles, 2 caballos y 8 peones.</p>
    </div>

    <div class="pieces-grid">
      {pieces.map((piece, i) => (
        <div class={`piece-card reveal reveal-delay-${(i % 3) + 1}`} data-piece={piece.slug}>
          <!-- CE-1: La imagen carga el SVG; si falla, el fallback JS lo gestiona -->
          <div class="piece-card__icon" aria-hidden="true">
            <img
              src={piece.icon}
              alt=""
              width="48"
              height="48"
              class="piece-card__svg"
              data-piece-fallback={piece.name[0]}
              onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
            />
            <span class="piece-card__fallback" style="display:none">{piece.name[0]}</span>
          </div>
          <div class="piece-card__body">
            <div class="piece-card__name-row">
              <h4 class="piece-card__name">{piece.name}</h4>
              <span class="piece-card__value" aria-label={`Valor: ${piece.value} puntos`}>{piece.value}</span>
            </div>
            <p class="piece-card__movement">{piece.movement}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- Subsección 3: Reglas fundamentales -->
    <div class="section-rules__rules-header reveal">
      <h3>Reglas fundamentales</h3>
      <p>Lo que necesitas saber para jugar tu primera partida.</p>
    </div>

    <div class="rules-grid">
      {rules.map((rule, i) => (
        <div class={`rule-card reveal reveal-delay-${(i % 3) + 1}`}>
          <span class="rule-card__icon" aria-hidden="true">{rule.icon}</span>
          <h4 class="rule-card__title">{rule.title}</h4>
          <p class="rule-card__desc">{rule.desc}</p>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .section-rules {
    padding-block: var(--space-24);
    background: var(--color-bg);
  }

  /* ─── Encabezado de sección ─────────────────────────────────────────────── */
  .section-rules__header {
    text-align: center;
    margin-bottom: var(--space-16);
  }

  .section-label {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-brown-main);
    margin-bottom: var(--space-3);
  }

  .section-rules__title {
    font-size: clamp(var(--text-3xl), 5vw, var(--text-5xl));
    color: var(--color-text);
    margin-bottom: var(--space-4);
  }

  .section-divider {
    width: 48px;
    height: 3px;
    background: var(--color-brown-main);
    margin-block: var(--space-4);
    border-radius: var(--radius-full);
    margin-inline: auto;
  }

  .section-rules__lead {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    max-width: 60ch;
    margin-inline: auto;
    line-height: 1.7;
  }

  /* ─── Info del tablero ──────────────────────────────────────────────────── */
  .section-rules__board-info {
    display: grid;
    gap: var(--space-10);
    margin-bottom: var(--space-20);
    align-items: center;
  }

  @media (min-width: 768px) {
    .section-rules__board-info {
      grid-template-columns: auto 1fr;
    }
  }

  .board-visual {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
  }

  .board-grid {
    display: grid;
    grid-template-columns: repeat(8, 1fr);
    width: clamp(160px, 30vw, 240px);
    aspect-ratio: 1;
    border: 3px solid var(--color-brown-main);
    border-radius: var(--radius-sm);
    overflow: hidden;
    box-shadow: var(--shadow-md);
  }

  .board-cell {
    aspect-ratio: 1;
  }

  .board-cell--light { background: var(--color-white-warm); }
  .board-cell--dark  { background: var(--color-green-main); }

  .board-label {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    letter-spacing: 0.05em;
  }

  .board-text h3 {
    font-size: var(--text-2xl);
    color: var(--color-text);
    margin-bottom: var(--space-4);
  }

  .board-text p {
    color: var(--color-text-muted);
    margin-bottom: var(--space-3);
    line-height: 1.7;
  }

  /* ─── Encabezados de subsección ─────────────────────────────────────────── */
  .section-rules__pieces-header,
  .section-rules__rules-header {
    margin-bottom: var(--space-8);
  }

  .section-rules__pieces-header h3,
  .section-rules__rules-header h3 {
    font-size: var(--text-2xl);
    color: var(--color-text);
    margin-bottom: var(--space-2);
  }

  .section-rules__pieces-header p,
  .section-rules__rules-header p {
    color: var(--color-text-muted);
  }

  /* ─── Grid de piezas (AC-4, AC-5) ───────────────────────────────────────── */
  .pieces-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-4);
    margin-bottom: var(--space-20);
  }

  @media (min-width: 1200px) {
    .pieces-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .piece-card {
    display: flex;
    align-items: flex-start;
    gap: var(--space-4);
    padding: var(--space-4) var(--space-5);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    transition:
      transform var(--duration-normal) var(--ease-smooth),
      box-shadow var(--duration-normal) var(--ease-smooth);
  }

  .piece-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-card-hover);
  }

  .piece-card__icon {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .piece-card__svg {
    width: 48px;
    height: 48px;
    color: var(--color-brown-main);
    /* Los SVGs usan currentColor */
    filter: invert(32%) sepia(40%) saturate(600%) hue-rotate(10deg) brightness(0.7);
  }

  /* CE-1: Fallback si el SVG no carga */
  .piece-card__fallback {
    width: 48px;
    height: 48px;
    background: var(--color-brown-main);
    color: var(--color-white);
    border-radius: var(--radius-md);
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    font-weight: 700;
    align-items: center;
    justify-content: center;
  }

  .piece-card__body {
    flex: 1;
    min-width: 0;
  }

  .piece-card__name-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-1);
  }

  .piece-card__name {
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--color-text);
  }

  .piece-card__value {
    font-size: var(--text-xs);
    font-weight: 700;
    color: var(--color-brown-main);
    background: rgba(107, 76, 42, 0.1);
    padding: 2px 8px;
    border-radius: var(--radius-full);
    letter-spacing: 0.05em;
  }

  .piece-card__movement {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  /* ─── Grid de reglas ─────────────────────────────────────────────────────── */
  .rules-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-4);
  }

  @media (min-width: 1200px) {
    .rules-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .rule-card {
    padding: var(--space-6);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    border-left: 3px solid var(--color-green-main);
  }

  .rule-card__icon {
    display: block;
    font-size: var(--text-2xl);
    margin-bottom: var(--space-3);
  }

  .rule-card__title {
    font-family: var(--font-serif);
    font-size: var(--text-base);
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: var(--space-2);
  }

  .rule-card__desc {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  /* ─── Mobile one column for very small screens ───────────────────────────── */
  @media (max-width: 480px) {
    .pieces-grid,
    .rules-grid {
      grid-template-columns: 1fr;
    }

    .piece-card {
      flex-direction: row;
    }
  }
</style>

<script>
  // AC-6: Intersection Observer para animaciones de entrada
  const reveals = document.querySelectorAll('#el-juego .reveal');
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1 }
  );
  reveals.forEach(el => observer.observe(el));
</script>
