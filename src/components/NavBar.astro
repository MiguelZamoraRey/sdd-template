---
/**
 * FEAT-004: Barra de navegación sticky con comportamiento transparente/sólido.
 * - AC-1: Transparente sobre el header hero
 * - AC-2: Fondo sólido oscuro tras el scroll
 * - AC-3: Ítems "El juego", "Historia", "Ajedrecistas"
 * - AC-4: Smooth scroll a las secciones
 * - AC-5: Ítem activo según sección visible
 * - AC-6/7: Menú hamburguesa en móvil
 * - AC-8: Accesibilidad con aria-* correctos
 */
const navItems = [
  { label: 'El juego',      href: '#el-juego'      },
  { label: 'Historia',      href: '#historia'      },
  { label: 'Ajedrecistas',  href: '#ajedrecistas'  },
];
---

<header class="navbar" id="navbar" role="banner">
  <div class="navbar__inner container">
    <!-- Logo / volver arriba -->
    <a href="#top" class="navbar__logo" aria-label="Fundamentos del Ajedrez — volver al inicio">
      <svg class="navbar__logo-icon" width="24" height="24" viewBox="0 0 45 45" fill="currentColor" aria-hidden="true">
        <path d="M22.5 11.63V6M20 8h5" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        <path d="M22.5 25s4.5-7.5 3-10.5c0 0-1-2.5-3-2.5s-3 2.5-3 2.5c-1.5 3 3 10.5 3 10.5" stroke="currentColor" stroke-width="1.5"/>
        <path d="M11.5 37c5.5 3.5 15.5 3.5 21 0v-7s9-4.5 6-10.5c-4-6.5-13.5-3.5-16 4V17s-5.5-6-10-3.5c-4 2-5 7.5 0 10.5v13z" stroke="currentColor" stroke-width="1.5"/>
      </svg>
      <span class="navbar__logo-text">Fundamentos</span>
    </a>

    <!-- Navegación desktop -->
    <nav aria-label="Navegación principal">
      <ul class="navbar__list" role="list">
        {navItems.map(item => (
          <li>
            <a href={item.href} class="navbar__link" data-nav-link>
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <!-- Botón hamburguesa (móvil) -->
    <button
      class="navbar__hamburger"
      id="hamburger-btn"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Abrir menú de navegación"
    >
      <span class="navbar__hamburger-line"></span>
      <span class="navbar__hamburger-line"></span>
      <span class="navbar__hamburger-line"></span>
    </button>
  </div>

  <!-- Menú móvil -->
  <nav
    id="mobile-menu"
    class="navbar__mobile-menu"
    aria-label="Navegación principal (móvil)"
    aria-hidden="true"
  >
    <ul class="navbar__mobile-list" role="list">
      {navItems.map(item => (
        <li>
          <a href={item.href} class="navbar__mobile-link" data-nav-link>
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>

<style>
  /* ─── Navbar ─────────────────────────────────────────────────────────────── */
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: var(--z-navbar);
    /* AC-1: transparente por defecto (sobre el hero) */
    background: transparent;
    transition:
      background var(--duration-normal) var(--ease-smooth),
      box-shadow var(--duration-normal) var(--ease-smooth);
  }

  /* AC-2: fondo sólido tras scroll — clase añadida por JS */
  .navbar.is-scrolled {
    background: var(--color-bg-dark);
    box-shadow: 0 2px 16px rgba(0, 0, 0, 0.4);
  }

  .navbar__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
  }

  /* ─── Logo ───────────────────────────────────────────────────────────────── */
  .navbar__logo {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--color-white);
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    font-weight: 700;
    letter-spacing: 0.02em;
    transition: opacity var(--duration-fast) var(--ease-smooth);
  }

  .navbar__logo:hover {
    opacity: 0.8;
  }

  .navbar__logo-icon {
    flex-shrink: 0;
    fill: none;
  }

  /* ─── Links desktop ──────────────────────────────────────────────────────── */
  .navbar__list {
    display: flex;
    gap: var(--space-8);
    list-style: none;
  }

  .navbar__link {
    color: var(--color-white);
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    position: relative;
    padding-block: var(--space-1);
    transition: color var(--duration-fast) var(--ease-smooth);
  }

  .navbar__link::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--color-brown-light);
    transition: width var(--duration-normal) var(--ease-smooth);
  }

  .navbar__link:hover::after,
  .navbar__link.is-active::after {
    width: 100%;
  }

  .navbar__link.is-active {
    color: var(--color-brown-light);
  }

  /* ─── Hamburguesa ───────────────────────────────────────────────────────── */
  .navbar__hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 40px;
    height: 40px;
    background: none;
    border: none;
    cursor: pointer;
    padding: var(--space-2);
  }

  .navbar__hamburger-line {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--color-white);
    border-radius: var(--radius-full);
    transition:
      transform var(--duration-normal) var(--ease-smooth),
      opacity var(--duration-normal) var(--ease-smooth);
  }

  /* Estado abierto */
  .navbar__hamburger[aria-expanded="true"] .navbar__hamburger-line:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .navbar__hamburger[aria-expanded="true"] .navbar__hamburger-line:nth-child(2) {
    opacity: 0;
  }
  .navbar__hamburger[aria-expanded="true"] .navbar__hamburger-line:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* ─── Menú móvil ─────────────────────────────────────────────────────────── */
  .navbar__mobile-menu {
    background: var(--color-bg-dark);
    overflow: hidden;
    max-height: 0;
    transition: max-height var(--duration-normal) var(--ease-smooth);
  }

  .navbar__mobile-menu.is-open {
    max-height: 300px;
  }

  .navbar__mobile-list {
    list-style: none;
    padding: var(--space-4) 0;
  }

  .navbar__mobile-link {
    display: block;
    padding: var(--space-3) var(--space-6);
    color: var(--color-white);
    font-size: var(--text-base);
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    transition: color var(--duration-fast) var(--ease-smooth),
                background var(--duration-fast) var(--ease-smooth);
  }

  .navbar__mobile-link:hover,
  .navbar__mobile-link.is-active {
    color: var(--color-brown-light);
    background: rgba(255, 255, 255, 0.04);
  }

  /* ─── Responsive ─────────────────────────────────────────────────────────── */
  @media (max-width: 767px) {
    .navbar__list {
      display: none;
    }
    .navbar__hamburger {
      display: flex;
    }
  }

  @media (min-width: 768px) {
    .navbar__mobile-menu {
      display: none;
    }
  }
</style>

<script>
  // AC-2: Detectar scroll para aplicar fondo sólido
  // AC-5: Marcar sección activa con IntersectionObserver
  // AC-6/7: Lógica del menú hamburguesa

  const navbar   = document.getElementById('navbar')!;
  const hamburger = document.getElementById('hamburger-btn')!;
  const mobileMenu = document.getElementById('mobile-menu')!;
  const navLinks   = document.querySelectorAll<HTMLAnchorElement>('[data-nav-link]');

  // AC-2: Scroll → fondo sólido
  const onScroll = () => {
    navbar.classList.toggle('is-scrolled', window.scrollY > 60);
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  // AC-6/7: Hamburguesa
  hamburger.addEventListener('click', () => {
    const isOpen = hamburger.getAttribute('aria-expanded') === 'true';
    hamburger.setAttribute('aria-expanded', String(!isOpen));
    mobileMenu.classList.toggle('is-open', !isOpen);
    mobileMenu.setAttribute('aria-hidden', String(isOpen));
    // Bloquear scroll del body cuando el menú está abierto
    document.body.style.overflow = isOpen ? '' : 'hidden';
  });

  // Cerrar menú al hacer clic en un ítem (AC-7)
  mobileMenu.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      hamburger.setAttribute('aria-expanded', 'false');
      mobileMenu.classList.remove('is-open');
      mobileMenu.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    });
  });

  // AC-5: Sección activa con IntersectionObserver
  const sections = document.querySelectorAll<HTMLElement>('section[id], div[id]');
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          navLinks.forEach(link => {
            const isActive = link.getAttribute('href') === `#${entry.target.id}`;
            link.classList.toggle('is-active', isActive);
          });
        }
      });
    },
    { rootMargin: '-50% 0px -50% 0px' }
  );

  sections.forEach(section => observer.observe(section));
</script>
