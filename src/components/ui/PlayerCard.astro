---
/**
 * FEAT-007: Tarjeta individual de ajedrecista
 * - AC-3: imagen, nombre, años, nacionalidad, descripción
 * - AC-4: alt descriptivo + loading="lazy"
 * - AC-9: hover con elevación (sombra + scale)
 * - CE-1/CE-2: placeholder con iniciales si no hay imagen
 */
import type { Player } from "../../data/players";

interface Props {
  player: Player;
  /** Delay de animación stagger en ms */
  delay?: number;
}

const { player, delay = 0 } = Astro.props;

// Iniciales para el placeholder (CE-1, CE-2)
const initials = player.name
  .split(" ")
  .filter((_, i) => i === 0 || i === player.name.split(" ").length - 1)
  .map((w) => w[0])
  .join("")
  .toUpperCase()
  .slice(0, 2);
---

<article
  class="player-card reveal"
  style={delay ? `transition-delay: ${delay}ms` : ""}
  aria-label={`Ajedrecista: ${player.name}`}
>
  <!-- Imagen / placeholder -->
  <div class="player-card__image-wrap">
    <img
      src={`/assets/players/${player.image}`}
      alt={`Fotografía de ${player.name}`}
      loading="lazy"
      width="300"
      height="300"
      class="player-card__img"
      onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
    />
    <!-- CE-1: placeholder con iniciales -->
    <div
      class="player-card__placeholder"
      style="display:none"
      aria-hidden="true"
    >
      <span>{initials}</span>
    </div>
  </div>

  <!-- Contenido -->
  <div class="player-card__body">
    <div class="player-card__meta">
      <span class="player-card__nationality">{player.nationality}</span>
    </div>
    <h3 class="player-card__name">{player.name}</h3>
    <p class="player-card__years">{player.years}</p>
    <p class="player-card__desc">{player.description}</p>
  </div>
</article>

<style>
  /* AC-9: hover con elevación */
  .player-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition:
      transform var(--duration-normal) var(--ease-smooth),
      box-shadow var(--duration-normal) var(--ease-smooth);
    box-shadow: var(--shadow-card);
  }

  .player-card:hover {
    transform: translateY(-6px) scale(1.01);
    box-shadow: var(--shadow-card-hover);
  }

  /* ─── Imagen ─────────────────────────────────────────────────────────────── */
  .player-card__image-wrap {
    position: relative;
    aspect-ratio: 1;
    overflow: hidden;
    background: var(--color-bg-dark);
  }

  .player-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    transition: transform var(--duration-slow) var(--ease-smooth);
  }

  .player-card:hover .player-card__img {
    transform: scale(1.05);
  }

  /* CE-1: Placeholder */
  .player-card__placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(
      135deg,
      var(--color-brown-main),
      var(--color-green-main)
    );
    align-items: center;
    justify-content: center;
    font-family: var(--font-serif);
    font-size: clamp(2rem, 6vw, 3rem);
    font-weight: 700;
    color: var(--color-white);
    letter-spacing: 0.05em;
  }

  /* ─── Cuerpo ─────────────────────────────────────────────────────────────── */
  .player-card__body {
    padding: var(--space-6) var(--space-6);
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .player-card__meta {
    margin-bottom: var(--space-2);
  }

  .player-card__nationality {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-brown-main);
  }

  .player-card__name {
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: var(--space-1);
    line-height: 1.2;
  }

  .player-card__years {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-green-main);
    margin-bottom: var(--space-3);
    line-height: 1.4;
  }

  .player-card__desc {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.65;
    flex: 1;
  }
</style>
